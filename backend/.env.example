# Copy to .env and fill with strong, unique values. NEVER commit .env to git.
# Generate strong values: openssl rand -base64 48

# ----- Postgres -----
POSTGRES_USER=shader_dojo_admin
POSTGRES_PASSWORD=replace-me-with-a-strong-password

# ----- JWT signing key (HS256: MUST be >= 32 bytes after UTF-8 encode) -----
JWT_KEY=replace-me-with-a-32-byte-or-longer-random-secret

# ----- Admin API key for Admin-Authorization header on /problems POST/PUT/DELETE -----
API_KEY=replace-me-with-a-uuid-or-random-secret

# ----- Validator shared secret (app <-> validator) -----
VALIDATOR_KEY=replace-me-with-a-random-shared-secret

# Optional tuning
# VALIDATOR_MAX_CONCURRENT_RENDERS=2
# VALIDATOR_RENDER_TIMEOUT_MS=5000

# ----- CORS -----
# Comma-separated origins that may call the JSON APIs in a browser.
# Behind the bundled nginx the frontend is same-origin so you usually don't need this.
# Set it only if you expose the backend on a different hostname.
CORS_ALLOWED_ORIGINS=

# ----- HTTP port nginx publishes on the host -----
HTTP_PORT=80

# ----- pgAdmin (only used with `docker compose --profile admin up`) -----
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=replace-me
# PGADMIN_PORT=7089
# DB_PORT=7088
